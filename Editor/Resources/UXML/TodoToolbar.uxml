<ui:UXML xmlns:ui="UnityEngine.UIElements" editor-extension-mode="True">
    <Style src="../USS/TodoToolbar.uss" />
    <ui:VisualElement name="ToolbarRow" class="row toolbar-row">
        <ui:Label text="TodoList 待办事项管理" class="bold-label-14" />
        <ui:VisualElement class="spacer" />
        <ui:Button name="ToolbarAddBtn" text="添加" class="toolbar-btn toolbar-add-btn" />
        <ui:Button name="ToolbarRefreshBtn" text="刷新" class="toolbar-btn" />
    </ui:VisualElement>
</ui:UXML>
